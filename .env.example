# Copy to .env on the EC2 instance and fill in real values (never commit .env).
# Used by docker-compose.prod.yml.

# Amazon RDS connection (MySQL 8)
DB_HOST=your-db.xxxxxxxx.eu-central-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=replace-with-rds-master-password
DB_NAME=lolsuit

# App secret for signing auth tokens
JWT_SECRET=replace-with-a-long-random-string
